MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=containerboard
# Public base URL used in canonical URLs, sitemap and metadata
NEXT_PUBLIC_SITE_URL=https://containerboard.pl
# Required for Vercel Blob media storage (company images and CV files)
BLOB_READ_WRITE_TOKEN=
# Optional Redis for faster rate limiting; leave empty to use MongoDB fallback
REDIS_URL=
# Optional Upstash REST Redis (preferred on Vercel serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy alias accepted for Upstash token
REDIS_TOKEN=
AUTH_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional; useful on localhost to force exact callback URL, e.g. http://localhost:3000/api/auth/google/callback
GOOGLE_REDIRECT_URI=
ADMIN_TOKEN=change-me
NEXT_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/019d175f-3c5a-7e45-8255-632ae385c9e8/style.json
NEXT_PUBLIC_MAPTILER_API_KEY=
RESEND_API_KEY=
MAIL_FROM=
MAIL_REPLY_TO=
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
